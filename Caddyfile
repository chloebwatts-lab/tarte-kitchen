{$DOMAIN} {
	# /log and /kitchen are public — staff walk-up entry on iPads, no login.
	# /council is public so the GCCC EHO can reach the password gate without
	# needing the staff basic-auth password (it has its own COUNCIL_PASSWORD
	# layer inside the app).
	# _next/static contains hashed build artefacts (JS/CSS) — safe to
	# serve without basic-auth so the public pages can load their
	# bundles.  All other routes (dashboard, API, etc.) stay protected.
	@protected {
		not path /log /log/*
		not path /kitchen /kitchen/*
		not path /council /council/*
		not path /api/council/*
		not path /api/auth/*
		not path /_next/static/*
		not path /favicon.ico
	}
	basic_auth @protected {
		tarte {$BASIC_AUTH_HASH}
	}

	reverse_proxy app:3000
}

# tarte-inbox — background email automation. Runs in /root/tarte-inbox under
# its own docker-compose, joined to this network (tarte-kitchen_default). Only
# OAuth callback URLs need to be reachable without basic-auth so Google/Xero
# can redirect back during the consent flow.
inbox.tarte.com.au {
	# /oauth/* and /health are public — they only kick off Google/Xero's own
	# login flows (which require authenticating as hello@ anyway), so basic
	# auth on top would just add a password prompt with no real security gain.
	@protected {
		not path /oauth/*
		not path /health
	}
	basic_auth @protected {
		tarte {$BASIC_AUTH_HASH}
	}

	reverse_proxy inbox:8787
}
