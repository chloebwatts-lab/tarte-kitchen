generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH
// ============================================================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  hashedPassword String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ============================================================
// SUPPLIERS
// ============================================================

model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique
  contact   String?
  phone     String?
  email     String?
  notes     String?
  /// ISO weekday numbers the supplier delivers on (1=Mon … 7=Sun). Empty
  /// array means unknown — PO suggestions fall back to a generic 7-day
  /// window.
  deliveryDays    Int[]   @default([])
  /// Hour-of-day (0–23, local time) after which orders placed get pushed
  /// to the next delivery day. Null = no cutoff modelled.
  orderCutoffHour Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingredients        Ingredient[]
  supplierPrices     SupplierPrice[]
  invoices           Invoice[]
  itemMappings       SupplierItemMapping[]
  emailAddresses     SupplierEmail[]
  purchaseOrders     PurchaseOrder[]
  approvedItems      ApprovedSupplierItem[]
}

// Approved supplier order forms — the "what we agreed to order from whom at
// what price". Used to spot cross-supplier misorders and price creep vs form.
model ApprovedSupplierItem {
  id           String    @id @default(cuid())
  supplierId   String
  supplier     Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name         String    // description as written on the supplier order form
  packSize     String?   // e.g. "2kg", "12.5kg bag", "case of 6"
  packPrice    Decimal   @db.Decimal(10, 2)
  unit         String?   // normalized unit, e.g. "kg", "each", "L"
  category     String?   // free-text grouping for the form UI
  notes        String?
  active       Boolean   @default(true)
  sortOrder    Int       @default(0)
  ingredientId String?
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([supplierId, name])
  @@index([supplierId])
  @@index([ingredientId])
}

model SupplierEmail {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  email      String   // e.g. "messaging-service@post.xero.com", "orders@fresho.com"
  createdAt  DateTime @default(now())

  @@unique([supplierId, email])
  @@index([email])
}

// ============================================================
// INGREDIENTS (Layer 1 — raw purchased items)
// ============================================================

enum BaseUnitType {
  WEIGHT // stored as grams
  VOLUME // stored as milliliters
  COUNT  // stored as "each"
}

enum IngredientCategory {
  MEAT
  SEAFOOD
  DAIRY
  CHEESE
  VEGETABLE
  FRUIT
  HERB
  MUSHROOM
  SPICE
  DRY_GOOD
  GRAIN
  FLOUR
  OIL
  VINEGAR
  BREAD
  BAKERY
  EGG
  CONDIMENT
  FROZEN
  SALAD
  OTHER
}

/// Australian FSANZ-mandated allergen declarations. Stored on Ingredient
/// and rolled up through preparations to dishes for menu display.
enum Allergen {
  MILK
  EGG
  FISH
  SHELLFISH
  CRUSTACEAN
  MOLLUSC
  TREE_NUT
  PEANUT
  WHEAT
  GLUTEN
  SOY
  SESAME
  LUPIN
  SULPHITE
}

model Ingredient {
  id                   String             @id @default(cuid())
  name                 String
  category             IngredientCategory @default(OTHER)
  baseUnitType         BaseUnitType       // WEIGHT, VOLUME, or COUNT

  // Purchase info
  supplierId           String?
  supplier             Supplier?          @relation(fields: [supplierId], references: [id])
  supplierProductCode  String?
  purchaseQuantity     Decimal            // e.g. 15 (dozen), 2350 (grams), 1 (kg)
  purchaseUnit         String             // e.g. "dozen", "g", "kg", "carton", "ea"
  purchasePrice        Decimal            // price in dollars (stored as cents-safe decimal)

  // Conversion to base units
  // For WEIGHT: how many grams in one purchaseUnit × purchaseQuantity
  // For VOLUME: how many ml in one purchaseUnit × purchaseQuantity
  // For COUNT: how many "each" in one purchaseUnit × purchaseQuantity
  baseUnitsPerPurchase Decimal            // e.g. eggs: 180 (15 dozen = 180 ea), bacon: 1000 (1kg = 1000g)

  // Cross-unit conversion (COUNT ingredients used in WEIGHT recipes)
  // e.g. avocado: 1 ea ≈ 200g → set to 200. Null for WEIGHT/VOLUME ingredients.
  gramsPerUnit         Decimal?           // grams (or ml for VOLUME) per single ea/bunch/etc.

  // Waste / trim
  wastePercentage      Decimal            @default(0) // 0–100, e.g. 38 for striploin

  // Par level for ordering. Legacy single-venue value — kept as a fallback
  // while we migrate callers to per-venue IngredientPar. When IngredientPar
  // has a row for a (ingredient, venue) pair, that takes precedence; this
  // field is only read for ingredients with no per-venue par set.
  parLevel             Decimal?
  parUnit              String?
  /// Per-venue par levels (one row per venue this ingredient is stocked at).
  /// Empty when nothing's been set yet; suggestOrders falls back to legacy
  /// parLevel/parUnit above.
  pars                 IngredientPar[]

  // Allergens declared on this ingredient. Rolled up through preparations
  // to dishes. FSANZ 1.2.3 compliance.
  allergens            Allergen[]         @default([])

  notes                String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  /// Canonical name — brand/pack-size stripped, used for cross-supplier
  /// grouping in the price alert system (so "American Burger cheese" and
  /// "Cheese Slices Burger Hi Melt" cluster as one item). Backfilled
  /// 2026-06-13. Populated by deterministic strip + sorted tokens.
  canonicalName        String?

  // Relations
  priceHistory         PriceHistory[]
  supplierPrices       SupplierPrice[]
  preparationItems     PreparationItem[]
  dishComponents       DishComponent[]
  wasteEntries         WasteEntry[]
  theoreticalUsages    TheoreticalUsage[]
  invoiceLineItems     InvoiceLineItem[]
  supplierMappings     SupplierItemMapping[]
  stocktakeItems       StocktakeItem[]
  purchaseOrderLines   PurchaseOrderLine[]
  approvedSupplierItems ApprovedSupplierItem[]
  priceAlerts          PriceAlert[]

  @@unique([name, supplierId])
  @@index([canonicalName])
}

/// Per-venue par level for an ingredient. Replaces the legacy Ingredient.parLevel
/// for any ingredient that has a row here. `source` records how the par got
/// there (SUGGESTED = generated from 4-week usage; MANUAL = chef-set) so we
/// can decide whether to overwrite on re-run of the suggestion engine.
model IngredientPar {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  venue        Venue
  parLevel     Decimal    @db.Decimal(12, 3)
  parUnit      String     // matches ingredient.purchaseUnit (kg, L, ea, etc.)
  source       ParSource  @default(MANUAL)
  notes        String?
  updatedBy    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([ingredientId, venue])
  @@index([venue])
}

enum ParSource {
  SUGGESTED      // legacy: from theoretical-usage suggestion engine
  MANUAL         // chef saved this value — never overwrite without confirmation
  AUTO_INVOICE   // computed from invoice purchase history (avg weekly qty over last 8 wk)
}

// Track every price change
model PriceHistory {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  oldPrice     Decimal
  newPrice     Decimal
  oldUnit      String?
  oldQuantity  Decimal?
  changedAt    DateTime   @default(now())
}

// Multiple supplier prices per ingredient
model SupplierPrice {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  supplierId   String
  supplier     Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  price        Decimal
  quantity     Decimal
  unit         String
  notes        String?
  updatedAt    DateTime   @updatedAt
  createdAt    DateTime   @default(now())

  @@unique([ingredientId, supplierId])
}

// ============================================================
// PREPARATIONS / SUB-RECIPES (Layer 2)
// ============================================================

enum PreparationCategory {
  SAUCE
  DRESSING
  MIX
  BASE
  PRESERVED
  PASTRY
  BREAD
  COMPONENT
  GARNISH
  OTHER
}

model Preparation {
  id               String              @id @default(cuid())
  name             String              @unique
  category         PreparationCategory @default(OTHER)
  method           String?             // rich text instructions

  // Yield
  yieldQuantity    Decimal             // e.g. 76 (serves) or 750 (grams)
  yieldUnit        String              // e.g. "serves", "g", "ml"
  yieldWeightGrams Decimal             // ALWAYS store total batch weight in grams

  // Auto-calculated costs (cached, updated on ingredient price changes)
  batchCost        Decimal             @default(0)
  costPerGram      Decimal             @default(0)
  costPerServe     Decimal             @default(0)

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  // Relations
  items            PreparationItem[]
  dishComponents   DishComponent[]
  // Self-referential: a preparation can be used in other preparations
  usedInItems      PreparationItem[]   @relation("SubPreparation")
  stockItems       PrepStockItem[]
}

model PreparationItem {
  id              String       @id @default(cuid())
  preparationId   String
  preparation     Preparation  @relation(fields: [preparationId], references: [id], onDelete: Cascade)
  sortOrder       Int          @default(0)

  // Either an ingredient or another preparation (sub-recipe)
  ingredientId    String?
  ingredient      Ingredient?  @relation(fields: [ingredientId], references: [id])
  subPreparationId String?
  subPreparation  Preparation? @relation("SubPreparation", fields: [subPreparationId], references: [id])

  quantity        Decimal      // amount used
  unit            String       // g, kg, ml, l, ea, serve

  // Cached cost for this line item
  lineCost        Decimal      @default(0)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

// ============================================================
// MENU ITEMS / DISHES (Layer 3 — what gets sold)
// ============================================================

enum MenuCategory {
  BREAKFAST
  LUNCH
  SIDES
  DRINKS
  KIDS
  DESSERT
  PASTRY
  SPECIAL
  OTHER
}

enum Venue {
  BURLEIGH
  BEACH_HOUSE
  TEA_GARDEN
  BOTH
}

enum SalesSource {
  API
  EMAIL
}

model Dish {
  id                 String       @id @default(cuid())
  name               String
  menuCategory       MenuCategory @default(OTHER)
  venue              Venue        @default(BOTH)

  // Pricing
  sellingPrice       Decimal      // inc GST
  sellingPriceExGst  Decimal      // auto: sellingPrice / 1.1

  // Auto-calculated
  totalCost          Decimal      @default(0)
  foodCostPercentage Decimal      @default(0) // (totalCost / sellingPriceExGst) × 100
  grossProfit        Decimal      @default(0) // sellingPriceExGst - totalCost

  // Menu engineering
  popularity         Int          @default(0) // number sold (manual or POS)

  notes              String?
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Relations
  components         DishComponent[]
  dailySales         DailySales[]
  wasteEntries       WasteEntry[]

  @@unique([name, venue])
}

model DishComponent {
  id              String       @id @default(cuid())
  dishId          String
  dish            Dish         @relation(fields: [dishId], references: [id], onDelete: Cascade)
  sortOrder       Int          @default(0)

  // Either an ingredient or a preparation
  ingredientId    String?
  ingredient      Ingredient?  @relation(fields: [ingredientId], references: [id])
  preparationId   String?
  preparation     Preparation? @relation(fields: [preparationId], references: [id])

  quantity        Decimal
  unit            String       // g, kg, ml, l, ea, serve

  // Cached cost for this line item
  lineCost        Decimal      @default(0)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

// ============================================================
// LIGHTSPEED POS INTEGRATION
// ============================================================

model LightspeedConnection {
  id                String   @id @default(cuid())
  accessToken       String   // Encrypted at rest via TOKEN_ENCRYPTION_KEY
  refreshToken      String   // Encrypted at rest
  tokenExpiresAt    DateTime
  businessId        String?
  businessLocations Json?    // Array of {id, name, venue} for multi-site
  connectedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================================
// DAILY SALES (synced from Lightspeed)
// ============================================================

model DailySales {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  venue           Venue    // BURLEIGH, BEACH_HOUSE, or TEA_GARDEN
  menuItemName    String
  menuItemId      String?  // Lightspeed item ID
  dishId          String?
  dish            Dish?    @relation(fields: [dishId], references: [id])
  quantitySold    Int
  revenue         Decimal  @db.Decimal(12, 2) // inc GST
  revenueExGst    Decimal  @db.Decimal(12, 2)
  voids           Int      @default(0)
  comps           Int      @default(0)
  source          SalesSource @default(API)
  createdAt       DateTime @default(now())

  @@unique([date, venue, menuItemName])
  @@index([date, venue])
  @@index([dishId])
}

model DailySalesSummary {
  id                String   @id @default(cuid())
  date              DateTime @db.Date
  venue             Venue
  totalRevenue      Decimal  @db.Decimal(12, 2)
  totalRevenueExGst Decimal  @db.Decimal(12, 2)
  totalCovers       Int
  averageSpend      Decimal  @db.Decimal(8, 2)
  totalVoids        Int
  totalComps        Int
  theoreticalCogs   Decimal? @db.Decimal(12, 2) // sales x recipe costs
  source            SalesSource @default(API)
  createdAt         DateTime @default(now())

  @@unique([date, venue])
}

// Idempotency record for Lightspeed EOD email imports
model LightspeedReportImport {
  id             String   @id @default(cuid())
  gmailMessageId String   @unique
  reportDate     DateTime @db.Date
  venue          Venue
  createdAt      DateTime @default(now())

  @@index([reportDate, venue])
}

// Top-N products per category per venue per day, mirrored from the
// Lightspeed EOD PDF's "Reporting Group Breakdown" section.
model DailyCategoryTopItem {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  venue        Venue
  categoryName String   // e.g. "Alcohol", "Cafe Food", "Coffee & Tea"
  productName  String
  quantity     Int
  rank         Int      // 1 = top seller in this category on this day
  createdAt    DateTime @default(now())

  @@unique([date, venue, categoryName, productName])
  @@index([date, venue])
  @@index([categoryName])
}

// ============================================================
// WASTAGE TRACKING
// ============================================================

enum WasteReason {
  OVERPRODUCTION
  SPOILAGE
  EXPIRED
  DROPPED
  STAFF_MEAL
  CUSTOMER_RETURN
  QUALITY_ISSUE
  OTHER
}

model WasteEntry {
  id            String      @id @default(cuid())
  date          DateTime    @db.Date
  venue         Venue
  dishId        String?
  dish          Dish?       @relation(fields: [dishId], references: [id])
  ingredientId  String?
  ingredient    Ingredient? @relation(fields: [ingredientId], references: [id])
  itemName      String      // Human-readable name (in case dish/ingredient not linked)
  quantity      Decimal     @db.Decimal(10, 3)
  unit          String
  reason        WasteReason
  estimatedCost Decimal     @db.Decimal(10, 2)
  notes         String?
  recordedBy    String?
  createdAt     DateTime    @default(now())

  @@index([date, venue])
  @@index([reason])
}

// ============================================================
// THEORETICAL USAGE (calculated from sales x recipes)
// ============================================================

model TheoreticalUsage {
  id              String     @id @default(cuid())
  date            DateTime   @db.Date
  venue           Venue
  ingredientId    String
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
  theoreticalQty  Decimal    @db.Decimal(12, 3)
  unit            String
  theoreticalCost Decimal    @db.Decimal(12, 2)
  createdAt       DateTime   @default(now())

  @@unique([date, venue, ingredientId])
}

// ============================================================
// GMAIL INTEGRATION
// ============================================================

model GmailConnection {
  id            String    @id @default(cuid())
  accessToken   String    // Encrypted at rest via TOKEN_ENCRYPTION_KEY
  refreshToken  String    // Encrypted at rest
  tokenExpiry   DateTime
  email         String    // The authenticated Gmail address
  lastScanAt    DateTime? // Watermark for polling — only fetch messages after this
  scanFrequency Int       @default(60)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model XeroConnection {
  id               String    @id @default(cuid())
  accessToken      String    // Encrypted at rest via TOKEN_ENCRYPTION_KEY
  refreshToken     String    // Encrypted at rest
  tokenExpiresAt   DateTime
  tenantId         String    // Xero organisation tenant ID
  organisationName String?
  connectedAt      DateTime  @default(now())
  lastSyncedAt     DateTime?
  updatedAt        DateTime  @updatedAt
}

model WeeklyLabourCost {
  id          String   @id @default(cuid())
  weekStart   DateTime // Monday of the week (midnight UTC)
  grossWages  Decimal  @db.Decimal(10, 2)
  superAmount Decimal  @db.Decimal(10, 2)
  totalCost   Decimal  @db.Decimal(10, 2) // grossWages + superAmount
  headcount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([weekStart])
  @@index([weekStart])
}

// ============================================================
// DEPUTY INTEGRATION — rostered & actual labour hours per venue
// ============================================================

model DeputyConnection {
  id             String    @id @default(cuid())
  /// Deputy subdomain (e.g. "tarte" in tarte.au.deputy.com)
  install        String
  region         String    @default("au") // au | na | eu
  accessToken    String    // Encrypted at rest
  refreshToken   String?   // Encrypted at rest — some Deputy plans only hand out long-lived tokens
  tokenExpiresAt DateTime?
  /// JSON array of { id, name, venue } mapping Deputy operational-unit /
  /// location ids to our Venue enum.
  locations      Json?
  /// On-cost multiplier applied on top of Deputy Roster.Cost when the
  /// labour tab displays scheduled wages. Deputy's Insights Summary bakes
  /// super into its totals; the API's Cost field does not. 0.12 = 12% super.
  superRate      Decimal   @default(0.12) @db.Decimal(5, 4)
  /// Fallback hourly rate used to cost Deputy "Open" (unfilled) shifts
  /// in the forecast. Default 0 so we match Deputy's Insights display
  /// (which doesn't cost open slots). Crank up in Settings if you want
  /// commitment estimates for unfilled hours.
  defaultOpenShiftRate Decimal @default(0) @db.Decimal(8, 2)
  /// Extra multiplicative uplift stacked on top of super (workers' comp +
  /// payroll tax). Deputy's Insights page factors these in but the Roster
  /// API's Cost/OnCost fields don't — so we apply it here. 0.0293 = 2.93%.
  /// Keep at 5 decimals so we can tune to match Insights to the cent.
  onCostUpliftRate Decimal @default(0) @db.Decimal(6, 5)
  connectedAt    DateTime  @default(now())
  lastSyncedAt   DateTime?
  updatedAt      DateTime  @updatedAt
}

/// One row per timesheet entry ingested from Deputy. Keyed by Deputy's
/// timesheet id for idempotent re-sync.
model LabourShift {
  id              String   @id @default(cuid())
  deputyId        String   @unique
  employeeName    String
  employeeId      String?  // Deputy employee id — useful for future drill-downs
  venue           Venue
  shiftStart      DateTime
  shiftEnd        DateTime
  hours           Decimal  @db.Decimal(6, 2)
  /// Gross cost = hours × payRate (pulled from Deputy). Encrypted? No —
  /// this is aggregated management data we already surface in labour %.
  cost            Decimal  @db.Decimal(10, 2)
  payRate         Decimal? @db.Decimal(8, 2)
  area            String?  // Deputy "Area" (e.g. "Kitchen", "Floor")
  approved        Boolean  @default(false)
  /// True when this is a Deputy "Open" shift (no employee assigned).
  /// We store cost as 0 on sync; the labour dashboard applies the
  /// configured open-shift $/hr rate at display time so it's tunable
  /// without a re-sync.
  isOpen          Boolean  @default(false)
  /// Which source this row came from. ROSTER = scheduled/forecast shift
  /// from Deputy's Roster resource (live/future weeks). TIMESHEET = actual
  /// shift from Deputy's Timesheet resource. Approved timesheets are what
  /// eventually settle into payroll.
  source          String   @default("TIMESHEET")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([venue, shiftStart])
  @@index([shiftStart])
  @@index([source])
}

/// Weekly per-venue actuals, uploaded or Xero-imported post-payroll.
/// Weeks are Wed–Tue; weekStartWed is the Wednesday UTC midnight.
///
/// Why separate from WeeklyLabourCost: that table is org-wide and indexed
/// by Monday ISO week; we need per-venue + Wed-week + a source trail.
model LabourWeekActual {
  id           String         @id @default(cuid())
  venue        Venue
  weekStartWed DateTime       @db.Date
  grossWages   Decimal        @db.Decimal(10, 2)
  superAmount  Decimal        @db.Decimal(10, 2) @default(0)
  totalHours   Decimal?       @db.Decimal(8, 2)
  headcount    Int?
  /// Manager's sales forecast for this week (ex GST) — what Deputy's
  /// Roster Insights uses as the denominator for the labour-% forecast.
  /// Captured alongside payroll actuals so the "was the week on-target?"
  /// retrospective can use the same number the manager was aiming at.
  mForecast    Decimal?       @db.Decimal(10, 2)
  // --- Rich management-report fields (from Mge PDF) ------------------
  /// Actual revenue (ex GST) for the week as reported on the Mge PDF.
  /// The source of truth for labour-% post-week — overrides mForecast
  /// as the denominator once actuals are uploaded.
  revenueExGst Decimal?       @db.Decimal(10, 2)
  /// Gross wages excluding admin/salary — matches what Deputy's Roster
  /// Insights shows (salary admin staff aren't in shift-level data).
  grossWagesExAdmin Decimal?  @db.Decimal(10, 2)
  /// Gross wages excluding admin + leave + toil + backpay. The cleanest
  /// apples-to-apples comparison with a rostered week.
  grossWagesExAdminLeaveBackpay Decimal? @db.Decimal(10, 2)
  /// Gross wages excluding leave + toil + backpay (admin still included).
  /// Mge PDF row: "Total less leave, toil, backpay".
  grossWagesLessLeaveBackpay Decimal? @db.Decimal(10, 2)
  // Per-department wage breakdown. Nullable so pre-PDF rows stay intact.
  wagesBarista Decimal?       @db.Decimal(10, 2)
  wagesChef    Decimal?       @db.Decimal(10, 2)
  wagesFoh     Decimal?       @db.Decimal(10, 2)
  wagesKp      Decimal?       @db.Decimal(10, 2)
  wagesPastry  Decimal?       @db.Decimal(10, 2)
  wagesAdmin   Decimal?       @db.Decimal(10, 2)
  /// Actual COGS $ for the week (from the Mge PDF's COGS box).
  cogsActual   Decimal?       @db.Decimal(10, 2)
  /// COGS as % of revenue, captured directly from the PDF so we don't
  /// re-derive and potentially mask rounding.
  cogsPct      Decimal?       @db.Decimal(5, 2)
  source       String         @default("UPLOAD") // UPLOAD | XERO | PDF
  notes        String?
  uploadId     String?
  upload       LabourUpload?  @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([venue, weekStartWed])
  @@index([weekStartWed])
}

/// Manager's weekly sales forecast (M. Forecast) per venue. Drives the
/// labour-% denominator for live + next week on /labour, matching
/// Deputy's Roster Insights Summary view.
model ManagerSalesForecast {
  id           String   @id @default(cuid())
  venue        Venue
  weekStartWed DateTime @db.Date
  /// Sales forecast in dollars EX GST. Industry-standard for labour %.
  amount       Decimal  @db.Decimal(10, 2)
  /// Where the number came from — MANUAL when a manager typed it in,
  /// DEPUTY when we scraped it from Deputy's Insights API.
  source       String   @default("MANUAL")
  enteredBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([venue, weekStartWed])
  @@index([weekStartWed])
}

/// One row per uploaded bookkeeper report. Holds the raw CSV + parse
/// metadata so we can re-parse / audit / delete an upload cleanly.
model LabourUpload {
  id         String             @id @default(cuid())
  filename   String
  rawCsv     String
  weekCount  Int                @default(0) // # of LabourWeekActual rows created
  uploadedBy String?
  createdAt  DateTime           @default(now())

  rows LabourWeekActual[]
}

/// Weekly per-venue COGS actuals, from the Thursday xlsx report Chris
/// uploads manually (Burleigh + Currumbin formats — Tea Garden rides
/// with Currumbin/Beach House). Complements LabourWeekActual.cogsActual
/// by breaking the total into category mix so we can spot supplier /
/// category drift week over week.
model WeeklyCogs {
  id             String        @id @default(cuid())
  venue          Venue
  weekStartWed   DateTime      @db.Date
  revenueExGst   Decimal?      @db.Decimal(10, 2)
  totalCogs      Decimal       @db.Decimal(10, 2)
  cogsPct        Decimal?      @db.Decimal(5, 2)
  cogsTargetPct  Decimal?      @db.Decimal(5, 2)
  // Category breakdown — nullable because not every venue reports
  // every category every week.
  cogsFood         Decimal? @db.Decimal(10, 2)
  cogsCoffee       Decimal? @db.Decimal(10, 2)
  cogsConsumables  Decimal? @db.Decimal(10, 2)
  cogsDrinks       Decimal? @db.Decimal(10, 2)
  cogsPackaging    Decimal? @db.Decimal(10, 2)
  source         String        @default("XLSX")
  uploadId       String?
  upload         CogsUpload?   @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([venue, weekStartWed])
  @@index([weekStartWed])
}

/// One row per uploaded COGS xlsx report. Mirrors LabourUpload — keeps
/// the raw extracted text + parse metadata for re-parse / audit.
model CogsUpload {
  id         String       @id @default(cuid())
  filename   String
  rawText    String
  weekCount  Int          @default(0)
  uploadedBy String?
  createdAt  DateTime     @default(now())

  rows          WeeklyCogs[]
  supplierLines CogsSupplierLine[]
}

/// Per-supplier spend per (venue, week) extracted from the same Thursday
/// xlsx. Lets us surface "Marrow Meats up 40% vs 4-week avg" style drift
/// in the COGS dashboard without re-parsing the file every render.
model CogsSupplierLine {
  id           String     @id @default(cuid())
  venue        Venue
  weekStartWed DateTime   @db.Date
  supplier     String
  amount       Decimal    @db.Decimal(10, 2)
  uploadId     String?
  upload       CogsUpload? @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([venue, weekStartWed, supplier])
  @@index([venue, weekStartWed])
  @@index([supplier])
}

// ============================================================
// LIVE SPEND TRACKING
// ============================================================

/// Per-venue COGS % target the live spend tracker grades the running
/// weekly invoice spend against. Manager forecast × targetPct = weekly
/// budget cap. Burleigh and BEACH_HOUSE seeded; TEA_GARDEN tracks with
/// BEACH_HOUSE for COGS but has its own row so future split is cheap.
model VenueCogsTarget {
  venue     Venue    @id
  targetPct Decimal  @db.Decimal(5, 2)
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// INVOICE MONITORING
// ============================================================

enum InvoiceStatus {
  PENDING
  PROCESSING
  EXTRACTED
  MATCHED
  APPROVED
  REJECTED
  ERROR
  /// Document is a supplier monthly statement (e.g. Provedores "MAY 2026"),
  /// not a delivery invoice. Stored for audit but excluded from all spend /
  /// variance aggregations — otherwise the month's deliveries get
  /// double-counted.
  STATEMENT
  /// Content-level duplicate of an already-ingested invoice (same supplier
  /// + invoice number, different Gmail message — typically a forward).
  /// Stored for audit, excluded from spend / variance sums.
  DUPLICATE
}

model Invoice {
  id              String        @id @default(cuid())
  gmailMessageId  String        @unique
  gmailThreadId   String?
  supplierName    String
  supplierId      String?
  supplier        Supplier?     @relation(fields: [supplierId], references: [id])
  venue           Venue?
  invoiceNumber   String?
  invoiceDate     DateTime?     @db.Date
  dueDate         DateTime?     @db.Date
  subtotal        Decimal?      @db.Decimal(12, 2)
  gst             Decimal?      @db.Decimal(12, 2)
  total           Decimal?      @db.Decimal(12, 2)
  status          InvoiceStatus @default(PENDING)
  pdfUrl          String?
  pdfFilename     String?
  rawEmailSubject String?
  rawEmailFrom    String?
  rawEmailDate    DateTime?
  extractedData   Json?
  errorMessage    String?
  processedAt     DateTime?
  approvedAt      DateTime?
  approvedBy      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lineItems       InvoiceLineItem[]

  @@index([status])
  @@index([supplierName])
  @@index([invoiceDate])
  @@index([venue])
}

model InvoiceLineItem {
  id              String      @id @default(cuid())
  invoiceId       String
  invoice         Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description     String
  quantity        Decimal?    @db.Decimal(12, 3)
  unit            String?
  unitPrice       Decimal?    @db.Decimal(12, 4)
  lineTotal       Decimal?    @db.Decimal(12, 2)
  ingredientId    String?
  ingredient      Ingredient? @relation(fields: [ingredientId], references: [id])
  mappingId       String?
  matchConfidence String?
  matchedName     String?
  currentPrice    Decimal?    @db.Decimal(12, 4)
  /// Invoice line's price expressed in the ingredient's purchase-unit base
  /// (per g / ml / ea). `unitPrice` is the raw invoice value — often per
  /// case/carton/pack — and not directly comparable to `currentPrice` when
  /// the supplier billed in a different unit. This field is set by the
  /// processor via compareUnits/evaluatePriceChange so all downstream
  /// consumers (digest, suppliers UI, dashboard, COGS variance) can do
  /// apples-to-apples comparisons without re-running unit conversion.
  /// Null when the comparison was "skip" or "unit_changed".
  normalisedUnitPrice Decimal? @db.Decimal(12, 6)
  priceChanged    Boolean     @default(false)
  priceApproved   Boolean?
  /// Pack/unit differs from the ingredient's stored purchase unit. Must be
  /// resolved (confirm conversion or remap) before the price can be applied.
  unitChanged     Boolean     @default(false)
  /// Auto-parsed from the line description (e.g. "Kale Carton 5kg" → 5).
  /// Pre-fills the conversion-confirm field on the unit-changed bucket.
  suggestedConversionFactor Decimal? @db.Decimal(12, 6)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([invoiceId])
  @@index([ingredientId])
}

model SupplierItemMapping {
  id                 String     @id @default(cuid())
  supplierId         String
  supplier           Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  invoiceDescription String
  ingredientId      String
  ingredient         Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  invoiceUnit        String?
  conversionFactor   Decimal?   @db.Decimal(12, 6)
  /// User has rejected this mapping as incorrect (e.g. "Milk Bun 100g"
  /// from Pixel Bread was auto-mapped to "Milk Bun (BreadTop)" — a
  /// different product). Ignored mappings short-circuit nothing — the
  /// matcher skips them so re-runs can find a correct match.
  ignored            Boolean    @default(false)
  ignoredAt          DateTime?
  ignoredBy          String?
  lastUsed           DateTime   @default(now())
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@unique([supplierId, invoiceDescription])
  @@index([ingredientId])
  @@index([supplierId, ignored])
}

// ============================================================
// STOCKTAKE — count inventory to reconcile against theoretical
// ============================================================

enum StocktakeStatus {
  DRAFT
  SUBMITTED
}

model Stocktake {
  id         String          @id @default(cuid())
  date       DateTime        @db.Date
  venue      Venue
  status     StocktakeStatus @default(DRAFT)
  // Total value of counted stock (sum of lineValue) and variance against
  // theoretical closing stock from the previous stocktake + receipts − usage.
  totalValue Decimal         @default(0) @db.Decimal(12, 2)
  notes      String?
  countedBy  String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  items StocktakeItem[]

  @@unique([date, venue])
  @@index([venue, date])
}

model StocktakeItem {
  id             String     @id @default(cuid())
  stocktakeId    String
  stocktake      Stocktake  @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
  ingredientId   String
  ingredient     Ingredient @relation(fields: [ingredientId], references: [id])
  // Count captured by staff, in the ingredient's natural purchase unit or
  // its base unit. We normalise to base units when computing variance so a
  // "2 kg" count and a "2000 g" count line up.
  countedQty     Decimal    @db.Decimal(12, 3)
  countedUnit    String
  countedBaseQty Decimal    @db.Decimal(12, 3) // normalised to base units
  unitCost       Decimal    @db.Decimal(12, 4) // cost per base unit at count time
  lineValue      Decimal    @db.Decimal(12, 2) // countedBaseQty * unitCost
  // Snapshot of the ingredient's expected on-hand at count time, driven by
  // previous stocktake + invoices received − theoretical usage since.
  expectedBaseQty Decimal?  @db.Decimal(12, 3)
  varianceBaseQty Decimal?  @db.Decimal(12, 3) // counted − expected
  varianceValue   Decimal?  @db.Decimal(12, 2)
  note           String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([stocktakeId, ingredientId])
  @@index([ingredientId])
}

// ============================================================
// CHECKLISTS / SOPs / TASK MANAGEMENT
// ============================================================

enum ChecklistCadence {
  DAILY
  WEEKLY
  MONTHLY
  ON_DEMAND
}

enum ChecklistShift {
  OPEN
  MID
  CLOSE
  ANY
}

enum ChecklistRunStatus {
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model ChecklistTemplate {
  id        String             @id @default(cuid())
  name      String
  /// Optional kitchen-area label (e.g. "Front of house", "Pastry section").
  area      String?
  venue     Venue              @default(BOTH)
  cadence   ChecklistCadence   @default(DAILY)
  shift     ChecklistShift     @default(ANY)
  /// HACCP / food safety checklists require temperature or evidence capture
  /// on each run. Surfaces in Reports → Food Safety.
  isFoodSafety Boolean          @default(false)
  /// Hour-of-day (0–23, AEST) by which this checklist must be complete.
  /// If still incomplete after this hour, the alert cron fires once per
  /// run and writes a ChecklistAlert row.
  dueByHour     Int?
  /// Emails that receive alerts when this template is overdue. Comma-free.
  alertEmails   String[]       @default([])
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  items  ChecklistTemplateItem[]
  runs   ChecklistRun[]
  alerts ChecklistAlert[]

  @@index([venue, cadence])
}

model ChecklistTemplateItem {
  id           String            @id @default(cuid())
  templateId   String
  template     ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sortOrder    Int               @default(0)
  label        String
  /// Optional longer instructions shown when the staff member opens the item.
  instructions String?
  /// HACCP capture hints — if set, the run item will require a temp / note.
  requireTemp  Boolean           @default(false)
  requireNote  Boolean           @default(false)
  /// Hot holding check: pass if ≥60°C. False (default) = cold check: pass if ≤5°C.
  hotCheck     Boolean           @default(false)
  /// Retired items keep their run history but are excluded from new runs.
  archived     Boolean           @default(false)

  runItems ChecklistRunItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChecklistRun {
  id         String             @id @default(cuid())
  templateId String
  template   ChecklistTemplate  @relation(fields: [templateId], references: [id])
  venue      Venue
  runDate    DateTime           @db.Date
  shift      ChecklistShift     @default(ANY)
  status     ChecklistRunStatus @default(IN_PROGRESS)
  completedBy String?
  completedAt DateTime?
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  items  ChecklistRunItem[]
  photos ChecklistRunPhoto[]

  @@unique([templateId, venue, runDate, shift])
  @@index([runDate, venue])
}

model ChecklistRunPhoto {
  id         String       @id @default(cuid())
  runId      String
  run        ChecklistRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  url        String
  publicId   String
  uploadedAt DateTime     @default(now())
  uploadedBy String?

  @@index([runId])
}

model ChecklistRunItem {
  id                 String                @id @default(cuid())
  runId              String
  run                ChecklistRun          @relation(fields: [runId], references: [id], onDelete: Cascade)
  templateItemId     String
  templateItem       ChecklistTemplateItem @relation(fields: [templateItemId], references: [id])
  /// Checked-off timestamp. Null until staff confirms the line.
  checkedAt          DateTime?
  checkedBy          String?
  tempCelsius        Decimal?              @db.Decimal(5, 2)
  note               String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@unique([runId, templateItemId])
}

/// One row per (template, venue, date) overdue event. Idempotent so the
/// cron can re-run every 15 minutes without spamming. `resolvedAt` is set
/// when the run is subsequently completed or cancelled.
model ChecklistAlert {
  id         String            @id @default(cuid())
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  venue      Venue
  runDate    DateTime          @db.Date
  /// Snapshot of the completion state at alert time.
  completedItems Int
  totalItems     Int
  emailedTo      String[]      @default([])
  emailedAt      DateTime?
  resolvedAt     DateTime?
  createdAt      DateTime      @default(now())

  @@unique([templateId, venue, runDate])
  @@index([resolvedAt])
}

// ============================================================
// PURCHASE ORDERS — auto-generated from par + usage, sent to supplier
// ============================================================

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  venue        Venue
  status       PurchaseOrderStatus @default(DRAFT)
  orderDate    DateTime            @db.Date
  expectedDate DateTime?           @db.Date
  subtotal     Decimal             @default(0) @db.Decimal(12, 2)
  notes        String?
  submittedBy  String?
  submittedAt  DateTime?
  /// Optional snapshot of the email we generated when submitting — lets
  /// us resend or inspect what went out without pulling Gmail back in.
  emailSubject String?
  emailTo      String?
  emailBody    String?
  /// Set when the snapshot was actually delivered via the Gmail
  /// integration. Distinct from `submittedAt`: a SUBMITTED order whose
  /// `emailSentAt` is null means the user still has to send the email
  /// manually (copy/paste or mailto).
  emailSentAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  lines PurchaseOrderLine[]

  @@index([supplierId, status])
  @@index([venue, orderDate])
}

model PurchaseOrderLine {
  id           String        @id @default(cuid())
  orderId      String
  order        PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  /// Optional — set when the line is a known TK ingredient (powers price-change
  /// detection on invoice match-back). When ordering an ApprovedSupplierItem
  /// that hasn't been linked to an Ingredient yet, this stays null and
  /// `description` carries the supplier-form text.
  ingredientId String?
  ingredient   Ingredient?   @relation(fields: [ingredientId], references: [id])
  /// Free-text description as it appears on the supplier order form. Required
  /// so emailed POs are readable even when no Ingredient is linked.
  description  String?
  quantity     Decimal       @db.Decimal(12, 3)
  unit         String
  unitPrice    Decimal       @db.Decimal(12, 4)
  lineTotal    Decimal       @db.Decimal(12, 2)
  /// Quantity received against this line (fill as the delivery arrives).
  /// Used for partial-delivery tracking & invoice reconciliation.
  receivedQty  Decimal?      @db.Decimal(12, 3)
  note         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([ingredientId])
  @@index([orderId])
}

// ============================================================
// COOLING LOGS — per-batch HACCP cooling record
// FSANZ 3.2.2A: cool from 60→21°C within 2 hr, 21→5°C within next 4 hr.
// ============================================================

model CoolingLog {
  id            String    @id @default(cuid())
  venue         Venue
  /// Item being cooled, e.g. "Beef stock", "Vanilla custard".
  itemName      String
  /// Free-form batch indicator, e.g. "20 L pot", "8x 1L containers".
  batchSize     String?
  /// When the food came off the heat / went into the cool room. Single
  /// canonical event time — defaults to now on entry, but the form allows
  /// override for late entries (forgotten earlier batches).
  startedAt     DateTime
  /// Initial temperature when leaving the heat source.
  startTempC    Decimal?  @db.Decimal(5, 2)
  /// Two-hour reading (target ≤21 °C). Time recorded so inspectors can see
  /// the actual interval, not just an assumed +2hr.
  twoHourTempC  Decimal?  @db.Decimal(5, 2)
  twoHourAt     DateTime?
  /// Six-hour reading (target ≤5 °C).
  sixHourTempC  Decimal?  @db.Decimal(5, 2)
  sixHourAt     DateTime?
  /// Fridge / cool room temp at finish, for context.
  fridgeTempC   Decimal?  @db.Decimal(5, 2)
  staffInitials String
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([venue, startedAt])
}

// ============================================================
// PASTRY ROTATION LOG — per-bake prepared / sold / discarded
// Staff fill this after each bake window so we can see waste, sell-through
// and total daily production without reading a paper sheet.
// ============================================================

enum PastryBakeTime {
  SIX_AM
  NINE_AM
  TWELVE_PM
}

model PastryProduct {
  id        String   @id @default(cuid())
  /// Display name — unique per venue so Burleigh and Beach House can have
  /// the same name without colliding.
  name      String
  venue     Venue    @default(BOTH)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries   PastryRotationEntry[]

  @@unique([venue, name])
  @@index([venue, isActive, sortOrder])
}

model PastryRotationEntry {
  id         String         @id @default(cuid())
  venue      Venue
  /// Day of record (AEST day). Stored as date only.
  entryDate  DateTime       @db.Date
  bakeTime   PastryBakeTime
  productId  String
  product    PastryProduct  @relation(fields: [productId], references: [id], onDelete: Cascade)
  prepared   Int            @default(0)
  sold       Int            @default(0)
  discarded  Int            @default(0)
  staffName  String?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([venue, entryDate, bakeTime, productId])
  @@index([venue, entryDate])
}

// ============================================================
// COUNCIL INSPECTION FOLDER — documents the EHO expects on-site
// (FSS certificate, pest reports, floor plan, training records, etc).
// Stored as bytea so deploys/rebuilds don't lose them and we don't need
// blob storage for what's a handful of small PDFs per venue per year.
// ============================================================

enum CouncilDocumentType {
  FOOD_BUSINESS_LICENCE
  FSS_CERTIFICATE
  FSS_NOTIFICATION
  PEST_CONTROL_REPORT
  FLOOR_PLAN
  TRAINING_RECORD
  CALIBRATION_RECORD
  CLEANING_SCHEDULE
  ALLERGEN_TRAINING
  HACCP_PLAN
  RECALL_PROCEDURE
  GREASE_TRAP_RECORD
  EAT_SAFE_RATING
  SUPPLIER_APPROVAL
  INCIDENT_LOG
  OTHER
}

model CouncilDocument {
  id          String              @id @default(cuid())
  venue       Venue
  type        CouncilDocumentType
  /// Display title — e.g. "FSS Certificate – John Smith" or "Pest control – Q2 2026".
  title       String
  description String?
  /// Date the document was issued / signed (for cert / pest report date).
  issuedOn    DateTime?           @db.Date
  /// Expiry date (for FSS — 5 years from issue, licence — annual).
  /// Used to surface red expiry warnings on the council page.
  expiresOn   DateTime?           @db.Date

  /// Original filename, MIME type, byte size, and the file itself.
  fileName    String
  mimeType    String
  fileSize    Int
  data        Bytes

  uploadedBy  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([venue, type])
  @@index([venue, expiresOn])
}

// ============================================================
// GOOGLE REVIEWS — pulled daily from the Places API for each
// venue, then tagged by Claude (sentiment + themes + staff
// mentions). Drives /reviews dashboard and Friday weekly summary
// email.
// ============================================================

enum ReviewSentiment {
  POSITIVE
  NEGATIVE
  MIXED
  NEUTRAL
}

enum ReviewTheme {
  FOOD_QUALITY
  COFFEE
  PASTRY
  SERVICE
  SPEED
  AMBIENCE
  VALUE
  CLEANLINESS
  STAFF_PRAISE
  STAFF_COMPLAINT
  WAIT_TIME
  ALLERGEN
  KIDS
  DIETARY
  RESERVATION
  OTHER
}

/// Snapshot per venue — refreshed every fetch with current
/// aggregate rating + total user-rating count, so we can chart
/// rating trend over time.
model GoogleVenuePlace {
  id               String   @id @default(cuid())
  venue            Venue    @unique
  placeId          String   @unique
  displayName      String
  formattedAddress String

  /// Business Profile location resource name (e.g.
  /// `accounts/12345/locations/67890`). Populated automatically after
  /// the OAuth dance — we match GBP locations to our venues by the
  /// shared Google Maps placeId returned from the GBP API. Once set,
  /// the reviews fetcher prefers GBP (paginated, all reviews) over the
  /// 5-cap Places API.
  gbpLocationName  String?  @unique

  // Latest snapshot (overwritten each fetch)
  rating           Decimal? @db.Decimal(3, 2)
  ratingCount      Int?
  lastFetchedAt    DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  reviews          GoogleReview[]
  ratingHistory    GoogleRatingSnapshot[]
}

/// Stored OAuth credential for the Google Business Profile API. Single-
/// tenant (one row at a time) — mirrors GmailConnection. Holds the
/// refresh token that lets the reviews cron call mybusiness.googleapis.com
/// without further user interaction.
model GbpConnection {
  id            String    @id @default(cuid())
  accessToken   String    // Encrypted at rest via TOKEN_ENCRYPTION_KEY
  refreshToken  String    // Encrypted at rest
  tokenExpiry   DateTime
  /// Google account email that completed the OAuth dance (display only).
  email         String
  /// The GBP account resource name we ingest from, e.g. "accounts/12345".
  /// Cached after the first listAccounts call so the cron doesn't have
  /// to re-discover it every run.
  accountName   String?
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/// Rating + count snapshot, one row per fetch — used to chart
/// rating drift week-over-week without losing history.
model GoogleRatingSnapshot {
  id          String   @id @default(cuid())
  placeId     String
  place       GoogleVenuePlace @relation(fields: [placeId], references: [placeId], onDelete: Cascade)
  venue       Venue
  rating      Decimal? @db.Decimal(3, 2)
  ratingCount Int?
  fetchedAt   DateTime @default(now())

  @@index([venue, fetchedAt])
}

model GoogleReview {
  id                String   @id @default(cuid())
  placeId           String
  place             GoogleVenuePlace @relation(fields: [placeId], references: [placeId], onDelete: Cascade)
  /// Denormalised for fast per-venue queries.
  venue             Venue

  /// Google's review name path — opaque but stable. Used as the
  /// dedupe key on ingest.
  googleReviewId    String   @unique

  // Content
  authorName        String?
  authorUri         String?
  authorPhotoUri    String?
  rating            Int      // 1–5
  text              String?
  originalText      String?
  languageCode      String?

  /// Absolute timestamp. The new Places API returns this on most
  /// reviews; if missing we fall back to fetchedAt and store the
  /// original relative description ("6 months ago") for display.
  publishTime       DateTime
  relativePublishTime String?

  // Owner reply (the venue's response, if any)
  replyText         String?
  replyTime         DateTime?

  // ── Tagging (Claude pass on ingest) ─────────────────────────
  sentiment         ReviewSentiment?
  themes            ReviewTheme[]    @default([])
  /// Free-form staff names extracted from the review text
  /// (lower-cased, deduped).
  staffMentions     String[]         @default([])
  /// One-sentence Claude summary so the dashboard list is
  /// scannable without reading every full review.
  taggedSummary     String?
  taggedAt          DateTime?

  // ── AI-drafted reply approval workflow ───────────────────────
  /// Lifecycle: null → DRAFTED (email sent) → APPROVED/SKIPPED → POSTED
  replyStatus       ReviewReplyStatus?
  /// Claude-generated reply draft, ready for Chloe to approve.
  draftReply        String?
  /// When the approval email was sent.
  draftSentAt       DateTime?
  /// One-time token embedded in approve/skip links.
  replyToken        String?   @unique
  /// When Chloe clicked Approve.
  approvedAt        DateTime?
  /// When the reply was successfully posted back to Google via GBP API.
  replyPostedAt     DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([venue, publishTime])
  @@index([venue, rating])
  @@index([venue, sentiment])
  @@index([replyStatus])
}

enum ReviewReplyStatus {
  DRAFTED   // email sent, awaiting Chloe's approval
  APPROVED  // approved — will post to Google (or posted already)
  POSTED    // successfully posted to Google via GBP API
  SKIPPED   // Chloe chose not to reply
}

/// **DEPRECATED** — superseded by `WeeklyDigest`. Kept in the schema
/// so existing rows aren't dropped, but no new rows are written.
/// The Friday Claude email is now a unified business digest (reviews
/// + COGS + wages + wastage + price spikes + top sellers) rather than
/// just reviews.
model GoogleReviewWeeklySummary {
  id           String   @id @default(cuid())
  /// Monday of the week being summarised (AEST).
  weekStart    DateTime @db.Date
  /// Sunday end of the same week.
  weekEnd      DateTime @db.Date
  reviewCount  Int
  /// Per-venue + overall summary, plus highlights, written by
  /// Claude. Body is Markdown.
  body         String
  emailedTo    String?
  emailedAt    DateTime?
  createdAt    DateTime @default(now())

  @@unique([weekStart])
}

// ============================================================
// WEEKLY DIGEST — Friday 08:00 AEST email to chloe@tarte.com.au.
// Single unified business overview: reviews, supplier price spikes,
// wastage patterns, COGS, labour vs target, top sellers, sales
// movement. Generated by Claude from the aggregator's structured
// snapshot. Stored so the dashboard can render last week's digest
// inline and so re-runs don't re-spend Anthropic credits.
// ============================================================

model WeeklyDigest {
  id           String   @id @default(cuid())
  /// Monday of the digest week (AEST). Reviews/sales/wastage cover
  /// Mon → Sun of this week; labour & COGS reference the most recent
  /// completed Wed→Tue payroll cycle (which may end earlier — call it
  /// out in the body).
  weekStart    DateTime @db.Date
  weekEnd      DateTime @db.Date

  // High-level metrics persisted alongside the prose so the dashboard
  // tile can render a snapshot without re-aggregating.
  reviewCount  Int      @default(0)
  reviewAvgRating Decimal? @db.Decimal(3, 2)
  salesTotal   Decimal? @db.Decimal(12, 2)
  salesWowPct  Decimal? @db.Decimal(6, 2)
  cogsAvgPct   Decimal? @db.Decimal(5, 2)
  labourAvgPct Decimal? @db.Decimal(5, 2)
  wastageTotal Decimal? @db.Decimal(10, 2)
  priceSpikeCount Int   @default(0)

  /// Full Markdown email body, generated by Claude.
  body         String
  /// Raw aggregator JSON snapshot — keeps the source of truth so we
  /// can regenerate or debug a past digest without re-querying.
  sourceJson   Json?

  emailedTo    String?
  emailedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([weekStart])
}

/// Audit log of every supplier-invoice-pull (check-invoices cron) run.
/// Drives the dashboard "ingestion healthy?" banner — if the latest
/// run is >36h old, errored, or has been returning 0 messages for 2+
/// consecutive days, we red-flag it on /dashboard so the next silent
/// failure surfaces inside a day instead of two weeks.
model InvoiceSyncRun {
  id                String   @id @default(cuid())
  startedAt         DateTime @default(now())
  finishedAt        DateTime?
  /// "incremental" (after:lastScanAt) or "sweep" (last-14-days, full
  /// re-scan that trusts the gmailMessageId @unique dedupe).
  mode              String
  messagesFound     Int      @default(0)
  invoicesIngested  Int      @default(0)
  duplicates        Int      @default(0)
  statements        Int      @default(0)
  errors            Int      @default(0)
  /// First 4000 chars of the error list, for in-DB triage without
  /// shelling into the droplet.
  errorSummary      String?
  /// Convenience flag — set false if the run threw before finish or
  /// errors > 0.5×messagesFound. Powers the dashboard "healthy" check.
  healthy           Boolean  @default(true)

  @@index([startedAt])
  @@index([mode, startedAt])
}

/// PDFs Gmail received from senders we don't have in the supplier-email
/// map. Caught by a separate cheap query (`subject:invoice OR tax OR
/// statement` from senders NOT in the known list). Surfaced in a
/// review queue at /suppliers/unmapped so a renamed sender (or a new
/// supplier) shows up to be linked, not silently swallowed.
model UnknownInvoiceSender {
  id              String   @id @default(cuid())
  senderEmail     String
  senderName      String?
  subject         String?
  gmailMessageId  String   @unique
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  occurrences     Int      @default(1)
  /// Set true once a human has linked the sender to a Supplier (or
  /// marked it "ignore — not an invoice"). Hidden from the review
  /// queue after that.
  resolved        Boolean  @default(false)
  resolvedNote    String?
  resolvedAt      DateTime?

  @@index([resolved, senderEmail])
}

// ============================================================
// PRICE ALERTS v2 — produce vs stable streams (built 2026-06-13)
// Replaces InvoiceLineItem.priceChanged single-row flag with a
// canonical-name-grouped alert state.
// See docs/price-alert-rebuild.md for design.
// ============================================================

enum PriceAlertStream {
  PRODUCE    // fresh produce: fruit / veg / herb / mushroom / salad
  STABLE     // everything else: dairy / dry / pantry / etc.
}

enum PriceAlertStatus {
  OPEN
  ACCEPTED   // chef confirmed new price → flowed to Ingredient.purchasePrice
  DISMISSED  // chef rejected (e.g. unit-mismatch ghost)
}

model PriceAlert {
  id                  String              @id @default(cuid())
  ingredientId        String
  ingredient          Ingredient          @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  /// Canonical group — so cross-supplier moves on the same effective product
  /// surface as one row, not N.
  canonicalName       String
  stream              PriceAlertStream
  /// Current invoice-derived price (per currentUnit).
  currentPrice        Decimal             @db.Decimal(12, 4)
  currentUnit         String
  /// Last known accepted price (per same unit). For PRODUCE this is the
  /// trailing-median target; for STABLE this is Ingredient.purchasePrice.
  priorPrice          Decimal             @db.Decimal(12, 4)
  /// PRODUCE only — 4-week trailing median used as the comparison floor.
  priorPeriodMedian   Decimal?            @db.Decimal(12, 4)
  changePct           Decimal             @db.Decimal(8, 2)
  /// Estimated weekly $ impact — usage rate × delta. Used for digest sort.
  weeklyImpactDollars Decimal?            @db.Decimal(10, 2)
  status              PriceAlertStatus    @default(OPEN)
  /// Supplier that triggered this alert (so chef knows who to chase).
  supplierName        String?
  firstSeenAt         DateTime            @default(now())
  lastSeenAt          DateTime            @default(now())
  resolvedAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([status, stream])
  @@index([canonicalName])
  @@index([ingredientId])
}

// ============================================================
// STAFF TRAINING (food handler records — Std 3.2.2A Tool 2)
// ============================================================

/// Per-staff food handler training record. Managers fill these in on the
/// venue iPad at /kitchen/training; a read-only list surfaces in the
/// /council folder's Training section. Date columns are date-only (no tz).
model TrainingRecord {
  id                 String    @id @default(cuid())
  venue              Venue
  staffName          String
  role               String?
  /// Online food handler course provider ("DoFoodSafely", "I'm Alert", ...).
  onlineCourse       String?
  onlineCourseDate   DateTime? @db.Date
  /// Completion certificate sighted / filed by the manager.
  certificateSighted Boolean   @default(false)
  allergenTrainedAt  DateTime? @db.Date
  inductionAt        DateTime? @db.Date
  illnessPolicyAt    DateTime? @db.Date
  recordsTrainedAt   DateTime? @db.Date
  /// Manager / Food Safety Supervisor who verified skills & knowledge.
  verifiedBy         String?
  verifiedAt         DateTime? @db.Date
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([venue, staffName])
}

// ============================================================
// KITCHEN RESTOCK & PREP COUNTS
// ============================================================

/// A physical kitchen within a venue. Beach House runs two (Restaurant +
/// Cafe); Burleigh and Tea Garden each run one (MAIN).
enum KitchenStation {
  RESTAURANT
  CAFE
  MAIN
}

enum RestockSheetStatus {
  IN_PROGRESS
  SUBMITTED
  RESTOCKED
}

/// Master catalogue of countable prep/stock items — one row per thing a
/// closing chef counts at a station (Egg mix, H.C.C., Lobster Mayo …).
/// Seeded from the head chef's paper sheets; managed in admin → Restock.
model PrepStockItem {
  id            String         @id @default(cuid())
  venue         Venue          @default(BEACH_HOUSE)
  station       KitchenStation
  name          String
  /// Count unit shown next to the number ("tub", "bottle", "tray", "kg").
  /// Null = freeform count, chefs know what a "2" means for this item.
  unit          String?
  /// Grouping header on the count sheet ("Station restock", "Daily prep").
  category      String         @default("Station restock")
  /// Target on-hand at start of service, in `unit`s. Shown as a hint so
  /// requests converge on a standard level.
  parLevel      Decimal?       @db.Decimal(8, 2)
  sortOrder     Int            @default(0)
  /// Optional link to the costed recipe once prep cards are loaded.
  preparationId String?
  preparation   Preparation?   @relation(fields: [preparationId], references: [id])
  notes         String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  lines RestockLine[]

  @@unique([venue, station, name])
  @@index([venue, station, isActive])
}

/// One end-of-shift count + restock request per station per day — the
/// closing chef's "Kitchen Restock Request" sheet, digitised.
model RestockSheet {
  id          String             @id @default(cuid())
  venue       Venue              @default(BEACH_HOUSE)
  station     KitchenStation
  sheetDate   DateTime           @db.Date
  status      RestockSheetStatus @default(IN_PROGRESS)
  countedBy   String?
  submittedAt DateTime?
  restockedBy String?
  restockedAt DateTime?
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  lines RestockLine[]

  @@unique([venue, station, sheetDate])
  @@index([venue, status])
}

model RestockLine {
  id         String        @id @default(cuid())
  sheetId    String
  sheet      RestockSheet  @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  itemId     String
  item       PrepStockItem @relation(fields: [itemId], references: [id])
  /// Counted on hand at close, in the item's unit. Null = not counted.
  available  Decimal?      @db.Decimal(8, 2)
  /// Amount the station needs for tomorrow. Null/0 = nothing requested.
  requested  Decimal?      @db.Decimal(8, 2)
  /// What the prep chef actually delivered on the morning run. Null on a
  /// requested line = shortfall; surfaces on the daily prep stock report.
  supplied   Decimal?      @db.Decimal(8, 2)
  priority   Boolean       @default(false)
  note       String?
  suppliedBy String?
  suppliedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([sheetId, itemId])
  @@index([itemId])
}
